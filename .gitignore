# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables / secrets
.env
.env.local

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# Data artifacts
data/raw/*
!data/raw/.gitkeep

# Bundled mock dataset is regenerable via `python -m src.pipeline.ingest`
data/mock/*.csv

# Model + generated artifacts (all regenerable via the pipeline)
data/processed/model.json
data/processed/model_meta.json
data/processed/*.png
data/processed/*.parquet
data/processed/narrative_cache.json

# Plots / images (keep README assets under docs/)
*.png
!docs/**/*.png

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
