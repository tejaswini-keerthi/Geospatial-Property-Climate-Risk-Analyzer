# ---------------------------------------------------------------------------
# Geospatial Property Climate Risk Analyzer - environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Toggle between mock data (default) and live API ingestion.
# When true, the pipeline reads data/mock/properties.csv and skips network calls.
MOCK_DATA=true

# Anthropic Claude API (used for climate-risk narratives)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_CONCURRENCY=5

# --- Real data provider API keys (only needed when MOCK_DATA=false) ---
# NOAA Climate Data Online: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_TOKEN=your-noaa-token-here
# FEMA National Flood Hazard Layer is public; base URL is configurable.
FEMA_NFHL_BASE_URL=https://hazards.fema.gov/gis/nfhl/rest/services
# Zillow / Bridge Interactive API
ZILLOW_API_KEY=your-zillow-key-here
# US Census Bureau: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your-census-key-here

# Pipeline paths (override only if you relocate data directories)
MOCK_DATA_PATH=data/mock/properties.csv
PROCESSED_DIR=data/processed
MODEL_PATH=data/processed/model.json

# Logging
LOG_LEVEL=INFO
